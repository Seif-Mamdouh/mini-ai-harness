# Pick ONE provider.

# Option A — OpenAI directly. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Option B — OpenRouter (OpenAI-compatible, one key for many models).
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Optional: override the model. The demo intentionally uses a weak model so the
# guardrails — not the prompt — are what carry it to success.
#   OpenAI:     MODEL=gpt-3.5-turbo
#   OpenRouter: MODEL=openai/gpt-3.5-turbo-0613
# MODEL=gpt-3.5-turbo

# Optional: Hacker News credentials for `npm run login`. If set, they're typed
# in automatically; if left blank you just log in by hand. This file (.env) is
# git-ignored, so nothing here is ever committed.
# HN_USERNAME=
# HN_PASSWORD=
